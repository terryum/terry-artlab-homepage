{
  "permissions": {
    "allow": [
      "Write",
      "Edit",
      "Read",
      "WebFetch(domain:*)",
      "Bash(git:*)",
      "Bash(node:*)",
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npm i:*)",
      "Bash(curl:*)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -q '.claude/skills/'; then bash scripts/sync-skills.sh; fi"
          }
        ]
      }
    ]
  }
}
